# ── Adzuna (agrégateur FR) ────────────────────────────────────────────────────
# Inscription gratuite : https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── France Travail (Pôle Emploi) ─────────────────────────────────────────────
# Inscription gratuite : https://francetravail.io
# Créer une application, ajouter le scope "Offres d'emploi v2"
FT_CLIENT_ID=
FT_CLIENT_SECRET=

# ── La Bonne Alternance ───────────────────────────────────────────────────────
# Token gratuit : https://api.apprentissage.beta.gouv.fr/fr/compte/profil
# → S'inscrire, aller dans "Mon compte", copier la clé API
LBA_API_KEY=

# ── IA — Génération de lettres ────────────────────────────────────────────────
# Groq (gratuit, rapide) : https://console.groq.com
GROQ_API_KEY=
# Gemini (vision pour l'agent) : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Options ───────────────────────────────────────────────────────────────────
# Inclure les offres remote dans les résultats IDF (1=oui, 0=non)
INCLURE_OFFRES_REMOTE=1

# ── Profil candidat ───────────────────────────────────────────────────────────
CANDIDAT_PRENOM=
CANDIDAT_NOM=
CANDIDAT_EMAIL=
CANDIDAT_TEL=
CANDIDAT_PORTFOLIO=
CANDIDAT_LINKEDIN=
CANDIDAT_GITHUB=
CV_PATH=
CANDIDAT_PRESENTATION=

# Parametres de l'agent
AGENT_CONFIRMATION_REQUIRED=1
AGENT_DELAY_SECONDS=5
AGENT_MAX_CANDIDATURES_SESSION=20
