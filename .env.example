# Adzuna
# Inscription gratuite : https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# France Travail
# Inscription gratuite : https://francetravail.io
# Creer une application, ajouter le scope "Offres d'emploi v2"
FT_CLIENT_ID=
FT_CLIENT_SECRET=

# La Bonne Alternance
# Token gratuit : https://api.apprentissage.beta.gouv.fr/fr/compte/profil
# S'inscrire, aller dans "Mon compte", puis copier la cle API
LBA_API_KEY=

# IA
# Groq : https://console.groq.com
GROQ_API_KEY=
# Gemini Vision pour l'agent : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Options de recherche
# Inclure les offres remote dans les resultats IDF (1=oui, 0=non)
INCLURE_OFFRES_REMOTE=1

# Profil candidat
CANDIDAT_PRENOM=
CANDIDAT_NOM=
CANDIDAT_EMAIL=
CANDIDAT_TEL=
CANDIDAT_PORTFOLIO=
CANDIDAT_LINKEDIN=
CANDIDAT_GITHUB=
CV_PATH=
CANDIDAT_PRESENTATION=

# Parametres de l'agent
AGENT_CONFIRMATION_REQUIRED=1
AGENT_DELAY_SECONDS=5
AGENT_MAX_CANDIDATURES_SESSION=20

# Demarrage / hebergement
# En local, tu peux laisser ces valeurs vides.
# En cloud, Render fournira PORT automatiquement.
APP_HOST=
APP_PORT=5001
PORT=
ALTERNANCE_CLOUD_MODE=0

# Stockage
# Laisser "local" pour le fonctionnement actuel.
# Ce point d'entree servira plus tard a brancher un stockage distant.
STORAGE_BACKEND=local

# Supabase
# Utilisees plus tard pour la synchronisation distante.
SUPABASE_URL=
# Cle publishable / anon pour l'authentification utilisateur dans le navigateur ou via le backend.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Laisser a 1 pour synchroniser automatiquement apres les actions importantes.
SUPABASE_SYNC_AUTO=1
# Mettre a 1 pour activer la connexion / creation de compte Supabase sur l'interface cloud.
SUPABASE_AUTH_ENABLED=0

# Protection d'acces optionnelle
# Si tu veux partager l'app sur un reseau local ou un hebergement de test,
# tu peux definir un token simple. L'interface demandera ce token au premier acces.
APP_SECRET=
# Optionnel : cle de session Flask distincte si tu veux la separer du token.
APP_SESSION_SECRET=
